{
  "name": "siakad",
  "version": "0.1.0",
  "private": true,
  "description": "Sistem Informasi Akademik Sekolah Indonesia — Web-based Progressive Web App (Next.js 15 + Prisma 7.8 + MariaDB)",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "queue:worker": "tsx src/shared/queue/worker.ts"
  },
  "dependencies": {
    "@prisma/adapter-mariadb": "7.8.0",
    "@prisma/client": "7.8.0",
    "@tanstack/react-query": "^5.59.0",
    "argon2": "^0.41.1",
    "bullmq": "^5.21.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "dompurify": "^3.1.7",
    "ioredis": "^5.4.1",
    "iron-session": "^8.0.4",
    "isomorphic-dompurify": "^2.16.0",
    "jose": "^5.9.4",
    "lucide-react": "^0.453.0",
    "mariadb": "^3.4.0",
    "next": "^15.5.0",
    "nodemailer": "^6.9.15",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.5.4",
    "uuid": "^10.0.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.7.5",
    "@types/nodemailer": "^6.4.16",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.13.0",
    "eslint-config-next": "^15.5.0",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "prisma": "7.8.0",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  },
  "engines": {
    "node": ">=20.10.0"
  }
}
