######################################################################
# SIAKAD — environment configuration template
# Copy to `.env` and adjust. NEVER commit actual secrets.
######################################################################

# --- Application ---
NODE_ENV=development
APP_URL=http://localhost:3000
APP_NAME="SIAKAD Sekolah Indonesia"
APP_TIMEZONE=Asia/Jakarta

# --- Database (MariaDB primary; see README for Postgres/Oracle/MSSQL migration) ---
#
# Baremetal / monolith setup (Node + MariaDB langsung di host):
#   Pakai `DATABASE_URL` saja. Ke-empat variabel `DB_*` di bawah cukup diabaikan
#   (mereka hanya dipakai oleh `docker-compose.yml`).
#
# Docker Compose setup (lihat README §7.2):
#   Variabel `DB_*` di bawah diteruskan ke container `mariadb` (membuat database,
#   user, dan password) DAN dipakai container `app`/`worker` untuk merakit
#   connection string. Anda tetap boleh meng-override `DATABASE_URL` di baris
#   bawah ini jika ingin connection string yang lebih spesifik (mis. menambah
#   parameter SSL).
#
# Format Prisma connection string. For MariaDB use the `mysql://` scheme.
DATABASE_URL="mysql://siakad:siakad@localhost:3306/siakad?connection_limit=20"
# Optional read-replica (Prisma client extension picks it up if set)
DATABASE_READ_URL=

# Hanya dipakai oleh docker-compose untuk mem-provision MariaDB dan merakit
# DATABASE_URL untuk container `app` & `worker`. Tidak dibaca oleh aplikasi
# saat dijalankan baremetal.
DB_NAME=siakad
DB_USER=siakad
DB_PASSWORD=siakad
DB_ROOT_PASSWORD=rootpw

# --- Auth / sessions ---
# 32+ random bytes, base64. Generate with: openssl rand -base64 48
AUTH_SESSION_SECRET="change-me-to-a-long-random-base64-string"
AUTH_JWT_SECRET="change-me-to-a-different-long-random-base64-string"
AUTH_JWT_ISSUER="siakad"
AUTH_JWT_AUDIENCE="siakad-users"
AUTH_SESSION_COOKIE_NAME="siakad_session"
AUTH_SESSION_TTL_HOURS=8
AUTH_REMEMBER_ME_TTL_DAYS=30

# --- Captcha ---
CAPTCHA_TTL_SECONDS=180
CAPTCHA_HMAC_SECRET="change-me-captcha-hmac-secret"

# --- Redis (cache + queue) ---
REDIS_URL="redis://localhost:6379/0"

# --- File storage ---
# 'local' or 's3'
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./storage
STORAGE_PUBLIC_URL_BASE=http://localhost:3000/uploads
S3_ENDPOINT=
S3_REGION=ap-southeast-3
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true

# --- Mail (SMTP) ---
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM="SIAKAD <no-reply@example.com>"

# --- WhatsApp gateway (provider abstraction) ---
WA_PROVIDER=disabled
WA_API_URL=
WA_API_KEY=
WA_SENDER_ID=

# --- Payment gateway (Midtrans + QRIS) ---
PAYMENT_PROVIDER=midtrans
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
QRIS_MERCHANT_ID=

# --- Security / rate limiting ---
RATE_LIMIT_LOGIN_PER_MINUTE=5
RATE_LIMIT_API_PER_MINUTE=120
ENABLE_HSTS_PRELOAD=false

# --- Feature flags ---
FEATURE_MFA_TOTP=false
FEATURE_PUSH_NOTIFICATIONS=true
FEATURE_PWA=true

# --- Observability ---
LOG_LEVEL=info
PINO_PRETTY=true
